# 飞书应用的 App ID，必填。
# 从飞书开放平台获取，例如：cli_xxxxxxxxxx
FEISHU_APP_ID=cli_xxxxxxxxxx

# 飞书应用的 App Secret，必填。
# 从飞书开放平台获取，请不要提交真实密钥。
FEISHU_APP_SECRET=xxxxxxxxxxxxxx

# 允许操作机器人的 open_id 白名单。
# 多个值使用英文逗号分隔；不在白名单内的用户会被直接拒绝。
FEISHU_ALLOWED_OPEN_IDS=ou_xxxxxxxxxx,ou_yyyyyyyyyy

# 当前使用的 Agent 类型。
# 可选值：claude / codex
# 默认值：claude
AGENT_PROVIDER=claude

# Agent 默认工作目录。
# 支持绝对路径；未设置时默认使用当前进程工作目录。
CLAUDE_WORK_ROOT=C:\work

# 群目录绑定持久化文件路径。
# 未设置时默认写入 data/chat-bindings.json
CHAT_BINDINGS_FILE=C:\work\cc-feishu\apps\typescript\data\chat-bindings.json

# Claude 模型名称。
# 仅在 provider=claude 时生效；未设置时使用代码内默认值。
CLAUDE_MODEL=claude-opus-4-6

# 本地单连接启动锁使用的 TCP 端口。
# 用于防止同一台机器同时启动多个机器人进程。
# 默认值：8652
SINGLE_INSTANCE_PORT=8652

# 运行环境标识。
# 常用值：development / production
# 默认值：development
NODE_ENV=development

# 日志级别。
# 可选值通常包括：error / warn / info / debug
# 默认值：info
LOG_LEVEL=info
