{
  "name": "cc-feishu-typescript",
  "version": "1.0.0",
  "description": "Feishu bot with WebSocket long connection",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "verify:codex-minimal": "npm run build && node dist/codex-minimal/verify.js",
    "test:chat-binding": "ts-node tests/chat-binding.test.ts",
    "test:group-chat-auto-bind": "ts-node tests/group-chat-auto-bind.test.ts",
    "test:private-chat-default-cwd": "ts-node tests/private-chat-default-cwd.test.ts",
    "test:stdio": "ts-node tests/stdio-protocol.test.ts",
    "test:multi-turn": "ts-node tests/multi-turn.test.ts",
    "test:tool-use": "ts-node tests/tool-use.test.ts",
    "test:tool-permission": "ts-node tests/tool-permission.test.ts",
    "test:multi-session": "ts-node tests/multi-session.test.ts"
  },
  "keywords": [
    "feishu",
    "bot",
    "websocket"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.29.0",
    "dotenv": "^16.4.5",
    "winston": "^3.11.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}


