# 飞书应用凭证
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxx

# 飞书 WebSocket 监控配置
FEISHU_HEALTH_CHECK_INTERVAL=60000    # 健康检查间隔（毫秒），默认 1 分钟
FEISHU_HEARTBEAT_TIMEOUT=300000       # 心跳超时（毫秒），默认 5 分钟

# Claude Code 配置
CLAUDE_WS_PORT=9800
CLAUDE_WORK_ROOT=/path/to/your/projects
CLAUDE_MODEL=claude-opus-4-6          # 可选: claude-opus-4-6 或 claude-sonnet-4-6（运行时可通过 /model 命令切换）

# 消息处理超时配置
MESSAGE_TIMEOUT=300000                # 消息处理超时（毫秒），默认 5 分钟
MESSAGE_TIMEOUT_ACTION=notify         # 超时后动作：notify（仅通知）或 kill（终止会话）

# CLI 进程健康检查配置
CLI_HEALTH_CHECK_INTERVAL=120000      # CLI 健康检查间隔（毫秒），默认 2 分钟
CLI_INACTIVE_TIMEOUT=300000           # CLI 无响应超时（毫秒），默认 5 分钟

# 会话空闲清理配置
SESSION_IDLE_TIMEOUT=3600000          # 会话空闲超时（毫秒），默认 1 小时
SESSION_IDLE_CLEANUP_INTERVAL=300000  # 空闲清理检查间隔（毫秒），默认 5 分钟
SESSION_NOTIFY_BEFORE_CLEANUP=true    # 清理前是否发送通知消息

# 流式输出配置（Card Kit streaming）
STREAMING_ENABLED=true
STREAMING_THROTTLE_MS=150

# 应用配置
NODE_ENV=development
LOG_LEVEL=info
